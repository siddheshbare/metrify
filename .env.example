# ─── Database ─────────────────────────────────────────────────────────────────
# Auto-injected by Vercel Neon integration in prod.
# For local dev: get these from your Neon project dashboard.
# "Pooled" connection string (used by the app at runtime via Prisma)
DATABASE_URL=

# "Direct" connection string (used by Prisma migrations only — no pooler)
DIRECT_URL=

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Your app URL (no trailing slash)
# Development: http://localhost:3000
# Production: https://your-domain.vercel.app
AUTH_URL=http://localhost:3000

# Required on Vercel (tells NextAuth to trust the host header)
AUTH_TRUST_HOST=true

# ─── Google OAuth (YouTube Data API + YouTube Analytics API) ──────────────────
# Get these from Google Cloud Console → APIs & Services → Credentials
# See architecture/env-setup.md for step-by-step instructions
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ─── Meta / Facebook (Instagram Business via Facebook Login) ──────────────────
# Get these from developers.facebook.com → App Settings → Basic
# See architecture/env-setup.md for step-by-step instructions
META_APP_ID=
META_APP_SECRET=

# The redirect URI registered in your Meta app's Facebook Login settings
# Development: http://localhost:3000/api/instagram/callback
# Production: https://your-domain.vercel.app/api/instagram/callback
META_REDIRECT_URI=http://localhost:3000/api/instagram/callback

# ─── Encryption ───────────────────────────────────────────────────────────────
# Used to encrypt the Instagram long-lived token at rest (AES-256-GCM)
# Must be a base64-encoded 32-byte random value
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=

# ─── Feature flags ────────────────────────────────────────────────────────────
# Set to "true" only when you want /c/[slug] pages indexed by search engines
# Default: "false" — adds <meta name="robots" content="noindex"> to public pages
NEXT_PUBLIC_INDEX_PUBLIC_PAGES=false
